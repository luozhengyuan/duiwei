COZE_WORKLOAD_IDENTITY_API_KEY=replace-with-valid-workload-identity-api-key
COZE_INTEGRATION_BASE_URL=https://api.coze.com
COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# 数据库连接
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Cloudflare Turnstile 人机验证（可选，不配置则关闭验证）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
